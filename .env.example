# ── Copy this file to .env and fill in your keys ──

# Anthropic API key (required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# The Odds API key (required for live odds)
# Free tier: 500 req/month — plenty for one daily run
# Get yours at: https://the-odds-api.com/
ODDS_API_KEY=your_odds_api_key_here

# Dollar value of 1 unit (set to your comfort level)
# Default: $50 — so 2u straight bets = $100 per play
UNIT_SIZE_DOLLARS=50
